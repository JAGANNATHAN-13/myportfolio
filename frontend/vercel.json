{
  "routes": [
    {
      "src": "/static/(.*)",
      "dest": "/static/$1"
    },
    {
      "src": "/admin(.*)",
      "dest": "https://myportfolio-653w.onrender.com/admin$1"
    },
    {
      "src": "/login(.*)",
      "dest": "https://myportfolio-653w.onrender.com/login$1"
    },
    {
      "src": "/logout(.*)",
      "dest": "https://myportfolio-653w.onrender.com/logout$1"
    },
    {
      "src": "/api/(.*)",
      "dest": "https://myportfolio-653w.onrender.com/api/$1"
    },
    {
      "src": "/projects",
      "dest": "/templates/projects.html"
    },
    {
      "src": "/(.*)",
      "dest": "/templates/index.html"
    }
  ]
}